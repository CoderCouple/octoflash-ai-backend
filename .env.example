# Application
APP_NAME=Octoflash AI Backend
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database
POSTGRES_USER=octoflash
POSTGRES_PASSWORD=octoflash
POSTGRES_DB=octoflash_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_SSL_REQUIRE=false

# CORS
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Temporal — two ways to configure:
#
# 1) Profile mode (preferred for local dev — keeps API keys out of this file).
#    Set up profiles via Temporal CLI:
#      temporal --profile local config set --prop address --value localhost:7233
#      temporal --profile cloud config set --prop address --value '<ns>.<account>.tmprl.cloud:7233'
#      temporal --profile cloud config set --prop namespace --value '<namespace>'
#      temporal --profile cloud config set --prop api_key --value '<paste>'
#    Then run:
#      TEMPORAL_PROFILE=cloud make worker
#    Profiles live in ~/Library/Application Support/temporalio/temporal.toml (macOS).
#
# 2) Env-var fallback (used in Docker / CI when TEMPORAL_PROFILE is unset).
TEMPORAL_PROFILE=
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_API_KEY=
TEMPORAL_TASK_QUEUE=octoflash-renders
TEMPORAL_WORKFLOW_ID_PREFIX=octoflash

# Anthropic (planner LLM)
ANTHROPIC_API_KEY=
PLANNER_MODEL=claude-sonnet-4-5

# AWS / S3
AWS_REGION=us-west-2
S3_BUCKET_RENDERS=octoflash-renders-dev
S3_BUCKET_EXPORTS=octoflash-exports-dev
S3_PUBLIC_BASE_URL=

# Whisper
WHISPER_MODEL=large-v3

# Manim
MANIM_QUALITY_PREVIEW=low_quality
MANIM_QUALITY_EXPORT=high_quality
MANIM_OUTPUT_DIR=./media
